---
import Layout from "../layouts/Layout.astro";
---

<Layout title="mesoHungry - Find Food Fast">
  <main>
    <img src="/cat-hungry-cat.gif" alt="Hungry cat" class="hero-gif" />
    <h1>mesoHungry</h1>
    <p>Find restaurants near you when hunger strikes.</p>
    <a href="https://play.google.com/store/apps/details?id=com.mesohungry.app" class="btn">Get the App</a>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 2rem;
  }

  .hero-gif {
    width: 280px;
    border-radius: 22px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 3rem;
    color: #228B22;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.2rem;
    color: #5C4A3A;
    margin-bottom: 2rem;
  }

  .btn {
    display: inline-block;
    padding: 0.8rem 2.5rem;
    background: #228B22;
    color: #fff;
    border-radius: 16px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background 0.2s;
  }

  .btn:hover {
    background: #1a6e1a;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2.2rem;
    }

    .hero-gif {
      width: 220px;
    }
  }
</style>
