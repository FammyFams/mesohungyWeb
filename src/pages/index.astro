---
import Layout from "../layouts/Layout.astro";
---

<Layout title="mesoHungy - Find Food Fast">
  <main>
    <img src="/cat-hungry-cat.gif" alt="Hungry cat" class="hero-gif" />
    <h1>mesoHungy</h1>
    <p>Find restaurants near you when hunger strikes.</p>
    <div class="badges">
      <a href="https://apps.apple.com/us/app/mesohungy/id6762582702">
        <img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" class="app-badge" />
      </a>
      <a href="https://play.google.com/store/apps/details?id=com.mesohungry.app">
        <img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" class="play-badge" />
      </a>
    </div>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 2rem;
  }

  .hero-gif {
    width: 280px;
    border-radius: 22px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 3rem;
    color: #228B22;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.2rem;
    color: #5C4A3A;
    margin-bottom: 2rem;
  }

  .badges {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .app-badge {
    height: 54px;
    transition: opacity 0.2s;
  }

  .play-badge {
    height: 80px;
    transition: opacity 0.2s;
  }

  .app-badge:hover,
  .play-badge:hover {
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2.2rem;
    }

    .hero-gif {
      width: 220px;
    }
  }
</style>
