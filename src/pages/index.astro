---
import Layout from "../layouts/Layout.astro";
---

<Layout title="mesoHungry - Find Food Fast">
  <main>
    <img src="/cat-hungry-cat.gif" alt="Hungry cat" class="hero-gif" />
    <h1>mesoHungry</h1>
    <p>Find restaurants near you when hunger strikes.</p>
    <a href="https://play.google.com/store/apps/details?id=com.mesohungry.app">
      <img src="https://play.google.com/intl/en_us/badges/static/images/badges/en_badge_web_generic.png" alt="Get it on Google Play" class="play-badge" />
    </a>
  </main>
</Layout>

<style>
  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: 2rem;
  }

  .hero-gif {
    width: 280px;
    border-radius: 22px;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 3rem;
    color: #228B22;
    margin-bottom: 0.75rem;
  }

  p {
    font-size: 1.2rem;
    color: #5C4A3A;
    margin-bottom: 2rem;
  }

  .play-badge {
    height: 80px;
    transition: opacity 0.2s;
  }

  .play-badge:hover {
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    h1 {
      font-size: 2.2rem;
    }

    .hero-gif {
      width: 220px;
    }
  }
</style>
